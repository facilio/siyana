---
// Animated "living building" — a tower whose HVAC/electrical/plumbing systems and the brands behind
// them feed a central Siyana "brain". Pure inline SVG + CSS (transforms/opacity), reduced-motion safe.
interface Props {
  brands?: string[];
}
const { brands = [] } = Astro.props;
const DEFAULT_BRANDS = ["Daikin", "Carrier", "Grundfos", "Trane", "LG", "TROX"];
const pool = (brands.length ? brands : DEFAULT_BRANDS).filter((b) => b.length <= 12);
const brandList = (pool.length ? pool : DEFAULT_BRANDS).slice(0, 4);
const brandY = [188, 272, 356, 440];
---

<div class="bb-wrap">
  <svg viewBox="0 0 480 560" class="bb" role="img" aria-label="A building whose systems and equipment brands feed a Siyana AI brain">
    <defs>
      <radialGradient id="bb-sky" cx="52%" cy="4%" r="80%">
        <stop offset="0" stop-color="#E0A458" stop-opacity="0.20" />
        <stop offset="0.5" stop-color="#D2693C" stop-opacity="0.06" />
        <stop offset="1" stop-color="#E0A458" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="bb-glass" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#1F2A37" />
        <stop offset="1" stop-color="#131A23" />
      </linearGradient>
      <radialGradient id="bb-core" cx="50%" cy="50%" r="50%">
        <stop offset="0" stop-color="#F7C982" />
        <stop offset="0.45" stop-color="#E0A458" />
        <stop offset="1" stop-color="#E0A458" stop-opacity="0" />
      </radialGradient>
      <filter id="bb-soft" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3.2" />
      </filter>
    </defs>

    <circle cx="262" cy="320" r="230" fill="url(#bb-sky)" />

    <!-- sky / weather cycle: sunrise → midday → rain → winter → sunset → night -->
    <g class="bb-weather">
      <circle class="bb-sun" cx="330" cy="46" r="26" />
      <g class="bb-cloud" fill="#3A485A">
        <ellipse cx="316" cy="56" rx="34" ry="17" />
        <ellipse cx="346" cy="50" rx="24" ry="15" />
        <ellipse cx="292" cy="50" rx="22" ry="14" />
      </g>
      <g class="bb-rain" stroke="#5EC8C2" stroke-width="2" stroke-linecap="round">
        {[290, 312, 334, 356].map((x, i) => (
          <line class="bb-drop" x1={x} y1="72" x2={x - 3} y2="83" style={`animation-delay:${i * 0.18}s`} />
        ))}
      </g>
      <g class="bb-snow" fill="#E7EBF0">
        {[296, 318, 340, 360].map((x, i) => (
          <circle class="bb-flake" cx={x} cy="74" r="2.2" style={`animation-delay:${i * 0.4}s`} />
        ))}
      </g>
    </g>

    <!-- ground -->
    <path d="M30 506c90-7 150-7 230 0s150 7 220 0" fill="none" stroke="#E7D8B4" stroke-width="2" opacity="0.22" />
    <line x1="30" y1="506" x2="450" y2="506" stroke="#2A3540" stroke-width="2" />

    <!-- ===== tower with depth ===== -->
    <polygon points="358,132 378,116 378,492 358,508" fill="#0F151D" stroke="#2A3540" stroke-width="1.5" />
    <rect x="150" y="132" width="208" height="376" rx="8" fill="url(#bb-glass)" stroke="#2A3540" stroke-width="2" />
    <!-- floor slabs -->
    {[188, 244, 300, 356, 412, 468].map((y) => (
      <g><line x1="150" y1={y} x2="358" y2={y} stroke="#2A3540" stroke-width="2" /><line x1="150" y1={y - 1.5} x2="358" y2={y - 1.5} stroke="#3a4757" stroke-width="0.8" opacity="0.6" /></g>
    ))}
    <!-- mullions -->
    {[192, 234, 276, 318].map((x) => <line x1={x} y1="138" x2={x} y2="502" stroke="#2A3540" stroke-width="1" opacity="0.7" />)}
    <!-- lit windows -->
    {[150, 206, 318, 430].map((fy, fi) =>
      [160, 202, 244, 286, 322].map((wx, wi) => (
        <rect x={wx} y={fy + 8} width="26" height="34" rx="2" fill="#5EC8C2" class="bb-win"
          style={`opacity:${(fi * 2 + wi) % 4 === 0 ? 0.45 : 0.1}; animation-delay:${(fi * 5 + wi) * 0.4}s`} />
      )),
    )}

    <!-- ===== rooftop plant ===== -->
    <rect x="158" y="104" width="200" height="28" rx="3" fill="#131A23" stroke="#2A3540" stroke-width="1.5" />
    <g transform="translate(190,104)"><circle r="15" fill="#0F151D" stroke="#2A3540" stroke-width="1.5" /><g class="bb-fan fast"><circle r="12" fill="none" /><path d="M0 0V-12M0 0L10.4 6M0 0L-10.4 6" stroke="#5EC8C2" stroke-width="3" stroke-linecap="round" /></g><circle r="2.5" fill="#E0A458" /></g>
    <g transform="translate(228,104)"><circle r="15" fill="#0F151D" stroke="#2A3540" stroke-width="1.5" /><g class="bb-fan"><circle r="12" fill="none" /><path d="M0 0V-12M0 0L10.4 6M0 0L-10.4 6" stroke="#5EC8C2" stroke-width="3" stroke-linecap="round" /></g><circle r="2.5" fill="#E0A458" /></g>
    <g transform="translate(316,104)">
      <ellipse cx="0" cy="-14" rx="9" ry="5" fill="#5EC8C2" opacity="0.18" class="bb-mist" />
      <rect x="-26" y="0" width="52" height="28" rx="3" fill="#0F151D" stroke="#2A3540" stroke-width="1.5" />
      <g transform="translate(0,14)"><g class="bb-fan slow"><circle r="9" fill="none" /><path d="M0 0V-9M0 0L7.8 4.5M0 0L-7.8 4.5" stroke="#E7D8B4" stroke-width="2.5" stroke-linecap="round" opacity="0.85" /></g></g>
    </g>

    <!-- ===== brand-knowledge feeds (left) ===== -->
    <g class="bb-bwires" fill="none" stroke="#E0A458" stroke-width="1.4" opacity="0.5">
      {brandList.map((_, i) => <path d={`M120 ${brandY[i] + 13} C 175 ${brandY[i] + 13}, 205 326, 254 326`} />)}
    </g>
    {brandList.map((b, i) => (
      <g class="bb-brand" style={`animation-delay:${i * 0.5}s`}>
        <rect x="22" y={brandY[i]} width="98" height="26" rx="13" fill="#171E27" stroke="#E0A458" stroke-width="1.2" />
        <circle cx="36" cy={brandY[i] + 13} r="3" fill="#E0A458" class="bb-led" style={`animation-delay:${i * 0.4}s`} />
        <text x="48" y={brandY[i] + 17} class="bb-brandtext">{b}</text>
      </g>
    ))}
    <text x="71" y="172" text-anchor="middle" class="bb-cap">BRAND KNOWLEDGE</text>

    <!-- ===== system wires (teal) ===== -->
    <g class="bb-wires" fill="none" stroke="#5EC8C2" stroke-width="1.6">
      <path d="M262 326 C 230 210, 218 150, 205 118" />
      <path d="M262 326 C 215 296, 205 270, 196 250" />
      <path d="M262 326 C 312 300, 326 282, 336 262" />
      <path d="M262 326 C 228 386, 214 430, 200 466" />
      <path d="M262 326 C 312 386, 326 418, 336 446" />
      <path d="M262 326 V 478" />
    </g>

    <!-- ===== system icons ===== -->
    <!-- AHU -->
    <g transform="translate(196,250)" class="bb-node"><rect x="-13" y="-11" width="26" height="22" rx="3" fill="#0F151D" stroke="#5EC8C2" stroke-width="1.5" /><circle r="6" fill="none" stroke="#5EC8C2" stroke-width="1.2" /><g class="bb-fan fast"><circle r="5" fill="none" /><path d="M0 0V-5M0 0L4.3 2.5M0 0L-4.3 2.5" stroke="#5EC8C2" stroke-width="1.4" stroke-linecap="round" /></g></g>
    <text x="196" y="276" text-anchor="middle" class="bb-cap">AHU</text>
    <!-- FCU -->
    <g transform="translate(336,262)" class="bb-node"><rect x="-13" y="-10" width="26" height="20" rx="3" fill="#0F151D" stroke="#5EC8C2" stroke-width="1.5" /><path d="M-8 -3h16M-8 1h16M-8 5h16" stroke="#5EC8C2" stroke-width="1.1" /></g>
    <text x="336" y="286" text-anchor="middle" class="bb-cap">FCU</text>
    <!-- electrical -->
    <g transform="translate(336,446)" class="bb-node"><rect x="-12" y="-12" width="24" height="24" rx="3" fill="#0F151D" stroke="#E0A458" stroke-width="1.5" /><path d="M3 -8 L-4 1 H1 L-2 8" fill="none" stroke="#E0A458" stroke-width="1.7" stroke-linejoin="round" /><circle class="bb-led" r="2" cx="8" cy="-8" fill="#E0A458" style="animation-delay:.5s" /></g>
    <text x="336" y="470" text-anchor="middle" class="bb-cap">ELEC</text>
    <!-- pump -->
    <g transform="translate(200,466)" class="bb-node"><circle r="13" fill="#0F151D" stroke="#5EC8C2" stroke-width="1.5" /><g class="bb-fan slow"><circle r="8" fill="none" /><path d="M0 0V-8M0 0L7 4M0 0L-7 4" stroke="#5EC8C2" stroke-width="2" stroke-linecap="round" /></g><circle r="1.8" fill="#E0A458" /></g>
    <text x="200" y="490" text-anchor="middle" class="bb-cap">PUMP</text>
    <!-- chiller label -->
    <text x="205" y="150" text-anchor="middle" class="bb-cap">CHILLER</text>

    <!-- people -->
    <g fill="#E7D8B4">
      {[244, 262, 280].map((x, i) => (
        <g class="bb-person" style={`animation-delay:${i * 0.5}s`}><circle cx={x} cy="478" r="3.4" /><rect x={x - 3} y="482.5" width="6" height="10" rx="3" /></g>
      ))}
    </g>
    <text x="262" y="500" text-anchor="middle" class="bb-cap">PEOPLE</text>

    <!-- ===== the brain ===== -->
    <g transform="translate(262,326)">
      <circle r="44" fill="url(#bb-core)" class="bb-glow" filter="url(#bb-soft)" />
      <circle r="25" fill="#0E1116" stroke="#E0A458" stroke-width="2" />
      <!-- neural net (nodes + synapses) -->
      <g stroke="#F7C982" stroke-width="1" opacity="0.85">
        <path d="M12 0L6 10.4M6 10.4L-6 10.4M-6 10.4L-12 0M-12 0L-6 -10.4M-6 -10.4L6 -10.4M6 -10.4L12 0" fill="none" />
        <path d="M12 0L-6 10.4M-6 -10.4L6 10.4M-12 0L6 -10.4" fill="none" opacity="0.5" />
      </g>
      {[[12,0],[6,10.4],[-6,10.4],[-12,0],[-6,-10.4],[6,-10.4]].map(([x,y],i)=>(
        <circle cx={x} cy={y} r="2.3" fill="#5EC8C2" class="bb-led" style={`animation-delay:${i*0.25}s`} />
      ))}
      <circle r="3" fill="#F7C982" />
      <circle r="25" fill="none" stroke="#E0A458" stroke-width="1.6" class="bb-ring" />
      <circle r="33" fill="none" stroke="#5EC8C2" stroke-width="1" stroke-dasharray="2 7" class="bb-spinring" opacity="0.7" />
    </g>
    <text x="262" y="392" text-anchor="middle" class="bb-brainlabel">Siyana</text>
  </svg>
</div>

<style>
  .bb-wrap { width: 100%; }
  .bb { width: 100%; height: auto; display: block; overflow: visible; }
  .bb-cap { font-family: "JetBrains Mono", monospace; font-size: 8.5px; letter-spacing: 1px; fill: #9AA6B3; }
  .bb-brandtext { font-family: "JetBrains Mono", monospace; font-size: 11px; fill: #E7D8B4; }
  .bb-brainlabel { font-family: "JetBrains Mono", monospace; font-size: 12px; letter-spacing: 2px; fill: #E7D8B4; }

  .bb-fan { transform-box: fill-box; transform-origin: center; animation: bb-spin 3.2s linear infinite; }
  .bb-fan.fast { animation-duration: 1.7s; }
  .bb-fan.slow { animation-duration: 5s; }
  @keyframes bb-spin { to { transform: rotate(360deg); } }

  .bb-wires path, .bb-bwires path { stroke-dasharray: 4 11; animation: bb-flow 1.7s linear infinite; }
  .bb-wires path { opacity: 0.6; }
  .bb-wires path:nth-child(odd) { animation-duration: 2.2s; }
  .bb-bwires path:nth-child(even) { animation-duration: 2.4s; }
  @keyframes bb-flow { to { stroke-dashoffset: -30; } }

  .bb-glow { transform-box: fill-box; transform-origin: center; animation: bb-pulse 3s ease-in-out infinite; }
  @keyframes bb-pulse { 0%,100% { opacity: 0.4; transform: scale(0.88); } 50% { opacity: 0.85; transform: scale(1.06); } }

  .bb-ring { transform-box: fill-box; transform-origin: center; animation: bb-ringpulse 3s ease-out infinite; }
  @keyframes bb-ringpulse { 0% { opacity: 0.7; transform: scale(1); } 100% { opacity: 0; transform: scale(1.7); } }

  .bb-spinring { transform-box: fill-box; transform-origin: center; animation: bb-spin 14s linear infinite; }

  .bb-led { animation: bb-blink 1.9s ease-in-out infinite; }
  @keyframes bb-blink { 0%,100% { opacity: 1; } 50% { opacity: 0.25; } }

  .bb-win { animation: bb-flicker 7s ease-in-out infinite; }
  @keyframes bb-flicker { 0%,100% { opacity: 0.1; } 48%,52% { opacity: 0.5; } }

  .bb-brand { transform-box: fill-box; transform-origin: center; animation: bb-breathe 3.6s ease-in-out infinite; }
  @keyframes bb-breathe { 0%,100% { opacity: 0.75; } 50% { opacity: 1; } }

  .bb-person { transform-box: fill-box; transform-origin: center; animation: bb-float 3.4s ease-in-out infinite; }
  @keyframes bb-float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-3px); } }

  .bb-mist { transform-box: fill-box; transform-origin: center; animation: bb-mist 3s ease-out infinite; }
  @keyframes bb-mist { 0% { opacity: 0; transform: translateY(4px) scale(0.7); } 50% { opacity: 0.25; } 100% { opacity: 0; transform: translateY(-8px) scale(1.3); } }

  .bb-sun { fill: #E0A458; transform-box: fill-box; transform-origin: center; animation: bb-day 26s ease-in-out infinite; }
  @keyframes bb-day {
    0%   { transform: translate(-118px, 92px) scale(.8);  fill: #D2693C; opacity: .25; }
    14%  { transform: translate(-64px, 34px) scale(.95);  fill: #E0A458; opacity: .9; }
    30%  { transform: translate(0, 0) scale(1.12);        fill: #F7C982; opacity: 1; }
    44%  { transform: translate(18px, 6px) scale(1.04);   fill: #F2B86E; opacity: 1; }
    54%  { transform: translate(48px, 26px) scale(.85);   fill: #E0A458; opacity: .3; }
    68%  { transform: translate(84px, 54px) scale(.8);    fill: #C9D3DE; opacity: .35; }
    84%  { transform: translate(120px, 84px) scale(.96);  fill: #D2693C; opacity: .85; }
    100% { transform: translate(150px, 120px) scale(.8);  fill: #9B4A2A; opacity: .1; }
  }
  .bb-cloud { transform-box: fill-box; transform-origin: center; opacity: 0; animation: bb-cloud 26s ease-in-out infinite; }
  @keyframes bb-cloud { 0%,44% { opacity: 0; transform: translateX(-12px); } 50% { opacity: .85; transform: translateX(0); } 72% { opacity: .6; } 80%,100% { opacity: 0; transform: translateX(12px); } }
  .bb-rain { opacity: 0; animation: bb-rainshow 26s ease-in-out infinite; }
  @keyframes bb-rainshow { 0%,46% { opacity: 0; } 50%,60% { opacity: .9; } 64%,100% { opacity: 0; } }
  .bb-drop { transform-box: fill-box; transform-origin: center; animation: bb-fall .9s linear infinite; }
  @keyframes bb-fall { 0% { transform: translateY(0); opacity: 0; } 25% { opacity: 1; } 100% { transform: translateY(20px); opacity: 0; } }
  .bb-snow { opacity: 0; animation: bb-snowshow 26s ease-in-out infinite; }
  @keyframes bb-snowshow { 0%,62% { opacity: 0; } 66%,78% { opacity: .95; } 82%,100% { opacity: 0; } }
  .bb-flake { transform-box: fill-box; transform-origin: center; animation: bb-snowfall 3s linear infinite; }
  @keyframes bb-snowfall { 0% { transform: translateY(0) translateX(0); opacity: 0; } 25% { opacity: 1; } 100% { transform: translateY(26px) translateX(5px); opacity: 0; } }

  @media (prefers-reduced-motion: reduce) {
    .bb-fan, .bb-wires path, .bb-bwires path, .bb-glow, .bb-ring, .bb-spinring, .bb-led, .bb-win, .bb-brand, .bb-person, .bb-mist, .bb-sun, .bb-cloud, .bb-rain, .bb-drop, .bb-snow, .bb-flake { animation: none; }
    .bb-wires path, .bb-bwires path { opacity: 0.5; }
  }
</style>
