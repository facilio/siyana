---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Siyana — the facilities-management brain for your AI",
  description = "Open-source MCP server delivering region-tuned facilities-management knowledge — specs, faults, PPM schedules, and live weather-aware energy estimates — inside Claude, Cursor, or any MCP client.",
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL("/og.png", Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/og.png", Astro.site).href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Noto+Naskh+Arabic:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Dataset",
      name: "Siyana",
      description,
      url: "https://siyana.dev",
      license: "https://creativecommons.org/licenses/by/4.0/",
      keywords: ["facilities management", "HVAC", "PPM", "maintenance", "MCP", "GCC", "knowledge base"],
      isAccessibleForFree: true,
      creator: { "@type": "Organization", name: "The Siyana contributors" },
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
